# Graphiti Memory Configuration
# This file is loaded directly by scripts/conf.py.
# Runtime environment variables still override values here.

# =============================================================================
# 0) REQUIRED IDENTITY + PATHS
# =============================================================================
export GRAPHITI_GROUP_ID="main-agent"
export MEMORY_DIR="${HOME}/.openclaw/workspace/memory"
export WORKSPACE_DIR="${HOME}/.openclaw/workspace"

# =============================================================================
# 1) NEO4J CONNECTION
# =============================================================================
export NEO4J_URI="bolt://localhost:7687"
export NEO4J_USER="neo4j"
# If Neo4j auth is disabled, keep false and password can be empty.
export NEO4J_AUTH_ENABLED="false"
export NEO4J_PASSWORD=""

# =============================================================================
# 2) LLM (EXTRACTION / DISTILL)
# =============================================================================
export LLM_API_KEY="${DASHSCOPE_API_KEY}"
export LLM_BASE_URL="https://coding.dashscope.aliyuncs.com/v1"
export LLM_MODEL="glm-5"

# Compatibility note:
# OPENAI_API_KEY is auto-filled from LLM_API_KEY by scripts/conf.py.
# export OPENAI_API_KEY="${LLM_API_KEY}"  # optional explicit override

# =============================================================================
# 3) RECALL + ARCHIVE TUNABLES
# =============================================================================
export GRAPHITI_RECALL_LIMIT="5"
export GRAPHITI_ARCHIVE_MIN_AGE_DAYS="30"
export GRAPHITI_ARCHIVE_MAX_QUERY_RATE="3"

# =============================================================================
# 4) EMBEDDING (UNIFIED AUTO MODE)
# =============================================================================
# Auto mode rule:
# - if EMBED_MODEL_PATH exists -> local llama.cpp embedding mode
# - otherwise -> API embedding mode

# Local default (llama.cpp server)
export EMBED_MODEL_PATH="${HOME}/.openclaw/models/gguf/Qwen3-Embedding-0.6B-Q8_0.gguf"
export EMBED_DIMS="512"
export EMBED_BASE_URL="http://127.0.0.1:8011"
export EMBED_ENDPOINT="/v1/embeddings"
export EMBED_MODEL=""
export EMBED_API_KEY=""
export EMBED_TIMEOUT="300"

# Example command to start local embedding service:
# llama-server \
#   -m "${EMBED_MODEL_PATH}" \
#   --embedding \
#   --host 127.0.0.1 --port 8011

# API example (uncomment to use API embedding mode):
# export EMBED_MODEL_PATH=""
# export EMBED_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# export EMBED_MODEL="text-embedding-v4"
# export EMBED_API_KEY="${DASHSCOPE_API_KEY}"
# export EMBED_TIMEOUT="300"
